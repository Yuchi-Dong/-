# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ── 必填 ─────────────────────────────────────────
SECFTP_SECRET_KEY=    # 运行: python3 -c "import secrets; print(secrets.token_hex(32))"
DB_PASS=              # 数据库密码（至少16字符）

# ── 可选 ─────────────────────────────────────────
DB_NAME=secftp
DB_USER=secftp
STORAGE_BACKEND=local        # local 或 minio

# MinIO（STORAGE_BACKEND=minio 时填写）
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=

# 监控
GRAFANA_PASSWORD=admin       # 生产环境请修改

# HTTPS
SECFTP_HTTPS=false           # 配置 SSL 证书后改为 true
